# SafeSignal AI — Apache .htaccess
# Protects sensitive directories and PHP API config files

Options -Indexes
ServerSignature Off

# Protect config and database directories
<FilesMatch "^(config|database|services)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent direct access to config.php anywhere
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Prevent direct access to .sql files
<FilesMatch "\.sql$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Set proper MIME types
AddType application/json .json

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options SAMEORIGIN
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compress text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg   "access plus 1 month"
    ExpiresByType image/png    "access plus 1 month"
    ExpiresByType image/webp   "access plus 1 month"
    ExpiresByType text/css     "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
